{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yarafie.github.io/awesome-ha-blueprints/schemas/manifest.schema.json",
  "title": "Awesome HA Library – Blueprint Manifest Schema",
  "description": "Single source of truth for blueprint metadata. Libraries are first-class and releases live under libraries.",
  "type": "object",
  "required": ["name", "description", "librarians", "libraries"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable blueprint name."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Blueprint description for listings and metadata."
    },
    "manufacturer": {
      "type": "string",
      "minLength": 1,
      "description": "Device manufacturer (required for controllers)."
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "description": "Device model identifier (required for controllers)."
    },
    "model_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable device model name (required for controllers)."
    },
    "librarians": {
      "type": "array",
      "minItems": 1,
      "description": "Curators responsible for defining this blueprint.",
      "items": { "$ref": "#/$defs/personRef" }
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags.",
      "items": { "type": "string" }
    },
    "external_references": {
      "type": "array",
      "description": "External reference links.",
      "items": { "$ref": "#/$defs/externalReference" }
    },
    "status": {
      "type": "string",
      "enum": ["active", "testing", "development", "retired", "deprecated"],
      "default": "active",
      "description": "Lifecycle status. Defaults to 'active'."
    },
    "libraries": {
      "type": "object",
      "minProperties": 1,
      "description": "Libraries for this blueprint, keyed by library ID. Releases are nested under each library.",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": { "$ref": "#/$defs/library" }
    }
  },
  "$defs": {
    "personRef": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "externalReference": {
      "type": "object",
      "required": ["label", "url"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "supportedControllers": {
      "type": "object",
      "required": ["controllers", "count"],
      "additionalProperties": false,
      "properties": {
        "controllers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supported_hooks": {
          "type": "array",
          "description": "Hook types supported by this controller release.",
          "items": { "type": "string" }
        },
        "supported_integrations": {
          "type": "array",
          "description": "Integrations supported by this release.",
          "items": { "type": "string" }
        },
        "supported_controllers": {
          "$ref": "#/$defs/supportedControllers"
        }
      }
    },
    "library": {
      "type": "object",
      "required": ["maintainers", "releases"],
      "additionalProperties": false,
      "properties": {
        "maintainers": {
          "type": "array",
          "minItems": 1,
          "description": "Maintainers of this library.",
          "items": { "$ref": "#/$defs/personRef" }
        },
        "requires_helper": {
          "type": "boolean",
          "description": "Whether this library requires the Helper - Last Controller Event input."
        },
        "has_long_press_loop": {
          "type": "boolean",
          "description": "Whether this library supports looping long press actions while a button is held."
        },
        "has_virtual_double_press": {
          "type": "boolean",
          "description": "Whether this library provides virtual double press events not natively supported by the device."
        },
        "supported_integrations": {
          "type": "array",
          "description": "Optional library-level default integrations, inherited by releases unless overridden.",
          "items": { "type": "string" }
        },
        "releases": {
          "type": "object",
          "minProperties": 1,
          "description": "Releases for this library, keyed by release ID.",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": { "$ref": "#/$defs/release" }
        }
      }
    }
  },
  "additionalProperties": false
}
